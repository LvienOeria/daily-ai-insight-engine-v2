{
  "report": {
    "timezone": "Asia/Shanghai",
    "window_days": 3,
    "min_items": 10,
    "max_items": 20
  },
  "llm": {
    "provider": "deepseek",
    "api_key_env": "DEEPSEEK_API_KEY",
    "base_url": "https://api.deepseek.com",
    "default_model": "deepseek-v4-flash",
    "report_model": "deepseek-v4-pro",
    "temperature": 0.2,
    "max_output_tokens": 8192,
    "json_outputs_required": true
  },
  "source_selection": {
    "mode": "fetch_then_evaluate",
    "candidate_fetch_required_before_selection": true,
    "select_core_sources_after_field_completeness_check": true,
    "chinese_websearch": {
      "enabled": true,
      "provider": "deepseek_websearch",
      "role": "compatibility_path",
      "allowed_sources": [
        {
          "name": "量子位",
          "domains": ["qbitai.com"]
        },
        {
          "name": "机器之心",
          "domains": ["jiqizhixin.com"]
        },
        {
          "name": "知乎",
          "domains": ["zhihu.com"]
        }
      ],
      "max_results": 20,
      "observation_file": "data/manual/chinese_websearch_observations.json",
      "selection_rule": "Fetched Chinese websearch results must be evaluated for required fields before entering the main dataset. Zhihu should be treated as community signal unless a specific item has traceable URL, source, published_at, and sufficient content."
    }
  },
  "frontend": {
    "framework": "react",
    "bundler": "vite",
    "package_manager": "pnpm",
    "visualization_library": "d3",
    "app_dir": "frontend",
    "data_output": "frontend/public/data/latest.json",
    "role": "display_only"
  },
  "output_paths": {
    "source_evaluation": "data/source_evaluation.json",
    "raw_news": "data/raw_news.json",
    "cleaned_news": "data/cleaned_news.json",
    "structured_news": "data/structured_news.json",
    "clustered_events": "data/clustered_events.json",
    "importance_scores": "data/importance_scores.json",
    "visualization_data": "data/visualization_data.json",
    "report": "reports/daily_ai_report.md",
    "quality_check": "reports/quality_check.json"
  }
}
