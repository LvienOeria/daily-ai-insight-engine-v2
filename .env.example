# Copy this file to .env and fill only the keys selected for the MVP.
# Never commit real API keys.

# LLM provider for local scripts.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REPORT_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=8192

# Optional news/search providers. Use only after source evaluation selects them.
NEWS_API_KEY=
GNEWS_API_KEY=
SERPAPI_API_KEY=
TAVILY_API_KEY=

# Optional: raises GitHub API rate limits for repository/release/community signals.
GITHUB_TOKEN=

# Runtime defaults for reproducible reports.
REPORT_TIMEZONE=Asia/Shanghai
REPORT_WINDOW_DAYS=3
REPORT_MIN_ITEMS=10
REPORT_MAX_ITEMS=20
SOURCE_SELECTION_MODE=fetch_then_evaluate
