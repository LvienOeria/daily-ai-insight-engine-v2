# Copy this file to .env and fill only the keys selected for the MVP.
# Never commit real API keys.

# LLM provider for local scripts.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REPORT_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=8192

# Chinese web search compatibility path.
# Keep the allowlist narrow for reproducibility and source-quality control.
DEEPSEEK_WEBSEARCH_ENABLED=true
DEEPSEEK_WEBSEARCH_ALLOWED_SITES=qbitai.com,jiqizhixin.com,zhihu.com
DEEPSEEK_WEBSEARCH_MAX_RESULTS=20
DEEPSEEK_WEBSEARCH_OBSERVATION_FILE=data/manual/chinese_websearch_observations.json

# Frontend output for the React/Vite/D3 dashboard.
FRONTEND_DATA_OUTPUT=frontend/public/data/latest.json

# Optional news/search providers. Use only after source evaluation selects them.
NEWS_API_KEY=
GNEWS_API_KEY=
SERPAPI_API_KEY=
TAVILY_API_KEY=

# Optional: raises GitHub API rate limits for repository/release/community signals.
GITHUB_TOKEN=

# Runtime defaults for reproducible reports.
REPORT_TIMEZONE=Asia/Shanghai
REPORT_WINDOW_DAYS=3
REPORT_MIN_ITEMS=10
REPORT_MAX_ITEMS=20
SOURCE_SELECTION_MODE=fetch_then_evaluate
